{
  "name": "@yamlresume/yamlresume",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "build:watch": "pnpm -r build:watch",
    "build:clean": "pnpm -r build:clean",
    "build:prod": "pnpm -r build:prod",
    "test": "pnpm -r test",
    "test:cov": "pnpm -r test:cov",
    "test:watch": "pnpm -r test:watch",
    "check": "pnpm check:biome --write && pnpm check:tsc && pnpm license:add",
    "check:ci": "pnpm check:biome && pnpm check:tsc && pnpm license:check",
    "check:tsc": "pnpm -r exec tsc --noEmit",
    "check:biome": "pnpm biome check --unsafe packages/*/src",
    "license:add": "node scripts/addlicense.mjs",
    "license:check": "node scripts/addlicense.mjs -c",
    "prepare": "husky",
    "publish:github": "pnpm build:prod && pnpm publish -r --no-git-checks --access public",
    "commitlint": "commitlint --edit",
    "release": "commit-and-tag-version -c .versionrc.cjs",
    "cli": "pnpm --filter yamlresume",
    "core": "pnpm --filter @yamlresume/core",
    "create-yamlresume": "pnpm --filter create-yamlresume",
    "json2yamlresume": "pnpm --filter json2yamlresume",
    "playground": "pnpm --filter @yamlresume/playground",
    "typedoc": "pnpm -r typedoc"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": "pnpm check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "commit-and-tag-version": "^12.7.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsup": "8.5.1",
    "tsx": "^4.23.1",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.12.1",
  "version": "0.13.2"
}
